# Runtime
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://posapi:posapi@localhost:5432/posapi?schema=public

# Redis 7 (idempotency + BullMQ)
REDIS_URL=redis://localhost:6379

# JWT (RS256 only — HS256 rejected)
# Cole o conteúdo da chave pública (formato PEM, com BEGIN/END) e mantenha as quebras de linha como \n
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<replace-me>\n-----END PUBLIC KEY-----"
JWT_ISSUER=fintech-pos-issuer

# Acquirer
ACQUIRER_BASE_URL=https://acquirer.example.com
ACQUIRER_API_KEY=replace-me
ACQUIRER_TIMEOUT_MS=25000

# Reconciliation async export threshold (default 10000)
RECONCILIATION_ASYNC_THRESHOLD=10000

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=fintech-pos-api
